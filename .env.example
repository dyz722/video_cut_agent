# 主模型协议: anthropic 或 openai -- 缺省时 CLI 会交互式询问
# MODEL_API_PROTOCOL=anthropic

# Anthropic-compatible (Anthropic 官方或三方 Messages API)
ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=
# MODEL_ID=claude-sonnet-4-6

# OpenAI-compatible (/v1/chat/completions)
# MODEL_API_PROTOCOL=openai
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# MODEL_ID=gpt-4o

# 阿里 DashScope (fun-asr / qwen3-vl-plus / cosyvoice-v3-flash)
# cn=国内 endpoint, intl=海外 endpoint；也可运行 /dashscope 配置
# DASHSCOPE_REGION=cn
DASHSCOPE_API_KEY=
# DASHSCOPE_API_KEY_CN=
# DASHSCOPE_API_KEY_INTL=
# DASHSCOPE_BASE_URL_CN=https://dashscope.aliyuncs.com/api/v1
# DASHSCOPE_BASE_URL_INTL=https://dashscope-intl.aliyuncs.com/api/v1

# 模型覆盖 (可选, 默认见 agent/config.py)
# VL_MODEL=qwen3-vl-plus
# ASR_FILE_MODEL=fun-asr
# ASR_REALTIME_MODEL=fun-asr-realtime
# TTS_MODEL=cosyvoice-v3-flash
